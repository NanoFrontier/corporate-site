---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;

type PageProps = {
  currentPage: number;
  totalPages: number;
  newsList: Array<{
    slug: string;
    data: { date: string; title: string; summary: string };
  }>;
};

export async function getStaticPaths() {
  const ITEMS_PER_PAGE = 20;

  const allNews = (await getCollection('news', ({ id }) => id.startsWith('ja/')))
    .sort((a, b) => b.data.date.localeCompare(a.data.date))
    .map(news => ({
      ...news,
      slug: news.slug.replace('ja/', ''),
    }));

  const totalPages = Math.ceil(allNews.length / ITEMS_PER_PAGE);

  const pages = Array.from({ length: totalPages }, (_, i) => i + 1).filter(p => p > 1);

  return pages.map(pageNum => ({
    params: { page: String(pageNum) },
    props: {
      currentPage: pageNum,
      totalPages,
      newsList: allNews.slice((pageNum - 1) * ITEMS_PER_PAGE, pageNum * ITEMS_PER_PAGE),
    } satisfies PageProps,
  }));
}

const { currentPage, totalPages, newsList } = Astro.props as PageProps;

const createPageUrl = (pageNum: number) => {
  if (pageNum === 1) return `${base}news/`;
  return `${base}news/page/${pageNum}/`;
};
---

<Layout
  title="ニュース・お知らせ | NanoFrontier - ナノフロンティア"
  description="NanoFrontier株式会社からのニュースやお知らせをご覧いただけます。"
  lang="ja"
  alternateUrls={{
    en: "https://nanofrontier.co.jp/en/news/",
    ja: "https://nanofrontier.co.jp/news/"
  }}
>
  <main class="container mx-auto px-4 py-12 pt-24">
    <h1 class="text-4xl font-bold mb-8" style="color:#04666c">ニュース・お知らせ</h1>
    <div class="space-y-6 mb-8">
      {newsList.map(news => (
        <a
          href={`${base}news/${news.slug}`}
          class="block bg-white rounded-xl border border-gray-200 shadow hover:shadow-lg transition-shadow p-6"
        >
          <div class="text-gray-500 text-sm mb-2">{news.data.date}</div>
          <h2 class="text-xl font-semibold mb-2" style="color:#04666c">{news.data.title}</h2>
          <p class="text-gray-700">{news.data.summary}</p>
        </a>
      ))}
    </div>

    {/* ページネーション */}
    {totalPages > 1 && (
      <div class="flex justify-center items-center gap-2 mt-8">
        {/* 前のページ */}
        {currentPage > 1 && (
          <a
            href={createPageUrl(currentPage - 1)}
            class="px-4 py-2 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 text-gray-700"
          >
            前のページ
          </a>
        )}

        {/* ページ番号 */}
        <div class="flex gap-2">
          {Array.from({ length: totalPages }, (_, i) => i + 1).map(pageNum => (
            <a
              href={createPageUrl(pageNum)}
              class={`px-4 py-2 rounded-lg ${
                currentPage === pageNum
                  ? 'bg-[#04666c] text-white'
                  : 'bg-white border border-gray-300 hover:bg-gray-50 text-gray-700'
              }`}
            >
              {pageNum}
            </a>
          ))}
        </div>

        {/* 次のページ */}
        {currentPage < totalPages && (
          <a
            href={createPageUrl(currentPage + 1)}
            class="px-4 py-2 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 text-gray-700"
          >
            次のページ
          </a>
        )}
      </div>
    )}
  </main>
</Layout>

